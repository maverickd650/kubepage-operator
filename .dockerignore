# More info: https://docs.docker.com/engine/reference/builder/#dockerignore-file
# Ignore everything by default and re-include only needed files
**

# Re-include Go source files (but not *_test.go)
!**/*.go
**/*_test.go

# Re-include Go module files
!go.mod
!go.sum

# Re-include embedded dashboard templates (internal/dashboard/server.go
# //go:embed templates/*.tmpl)
!**/templates/*.tmpl

# Re-include embedded dashboard fonts, vendored htmx, and the PWA icon
# (internal/dashboard/server.go //go:embed assets/*.woff2 assets/*.js assets/*.svg)
!**/assets/*.woff2
!**/assets/*.js
!**/assets/*.svg
