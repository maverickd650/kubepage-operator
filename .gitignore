# If you prefer the allow list template instead of the deny list, see community template:
# https://github.com/github/gitignore/blob/main/community/Golang/Go.AllowList.gitignore
#
# Binaries for programs and plugins
*.exe
*.exe~
*.dll
*.so
*.dylib
*.DS_Store

# Test binary, built with `go test -c`
*.test

# Code coverage profiles and other test artifacts
*.out
coverage.*
*.coverprofile
profile.cov

# pgregory.net/rapid failure-reproduction caches (auto-written next to the
# test package on a rapid.Check failure; local debugging artifacts only)
**/testdata/rapid/

# visual_test.go's actual-capture artifact, written next to a golden PNG
# only when a comparison fails (see compareVisualGolden) — local/CI-artifact
# debugging output, never a golden file itself.
internal/dashboard/testdata/visual/*.got.png

# Dependency directories (remove the comment below to include it)
# vendor/

# Go workspace file
go.work
go.work.sum

# env file
.env

# mise task output / local tool binaries
/bin/
/dist-bin/

# per-checkout golangci-lint issue cache (see GOLANGCI_LINT_CACHE in .mise/config.toml)
/.cache/

# Local-only working notes, never pushed
/IMPLEMENTATION_PLAN.md

# Editor/IDE
# .idea/
.vscode/
