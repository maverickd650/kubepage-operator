{{if gt (len .Tabs) 1}}
  <div class="tabs" role="tablist">
    {{range $i, $t := .Tabs}}
      <button type="button" class="tab-btn{{if eq $i 0}} active{{end}}" onclick="showTab({{$i}})">{{.Name}}</button>
    {{end}}
  </div>
{{end}}
{{range $i, $t := .Tabs}}
  <div class="tab-panel{{if ne $i 0}} hidden{{end}}">
    {{range .Groups}}
      <h2>{{if .IconURL}}<img class="icon" src="{{.IconURL}}" alt="">{{end}} {{.Name}}</h2>
      <div class="grid{{if eq .Style "row"}} grid-row{{end}}"{{if .Columns}} style="grid-template-columns: repeat({{.Columns}}, 1fr);"{{end}}>
        {{range .Cards}}
          <div class="card" id="card-{{.Key}}" data-name="{{.ServiceName}}" data-description="{{.Description}}">
            <h3>
              {{if .IconURL}}<img class="icon" src="{{.IconURL}}" alt="">{{end}}
              {{if .Href}}<a href="{{.Href}}" target="{{if .Target}}{{.Target}}{{else}}{{$.SiteTarget}}{{end}}">{{.ServiceName}}</a>{{else}}{{.ServiceName}}{{end}}
              {{if .Status}}
                {{if eq .StatusStyle "dot"}}<span class="status-dot status-{{.Status}}" title="{{.Status}}{{if .Latency}} · {{.Latency}}{{end}}"></span>
                {{else if ne .StatusStyle "basic"}}<span class="status-pill status-{{.Status}}" title="{{.Status}}">{{if .Latency}}{{.Latency}}{{else}}{{.Status}}{{end}}</span>{{end}}
              {{end}}
            </h3>
            {{if .Description}}<div class="desc">{{.Description}}</div>{{end}}
            {{if and .Status (eq .StatusStyle "basic")}}
              <div class="field"><span class="label">Status</span><span>{{.Status}}{{if .Latency}} · {{.Latency}}{{end}}</span></div>
            {{end}}
            {{if .Err}}
              <div class="err">{{.Err}}</div>
            {{else if .Fields}}
              <div class="stats">
                {{range .Fields}}<div class="stat"><span class="label">{{.Label}}</span><span class="value">{{.Value}}</span></div>{{end}}
              </div>
            {{end}}
          </div>
        {{end}}
      </div>
    {{end}}
  </div>
{{end}}
{{range .BookmarkGroups}}
  <h2>{{.Name}}</h2>
  <div class="grid">
    {{range .Bookmarks}}
      <a class="card bookmark" href="{{.Href}}" target="{{$.SiteTarget}}" data-name="{{.Name}}" data-description="{{.Description}}">
        {{if .IconURL}}<img class="icon" src="{{.IconURL}}" alt="">{{else if .Abbr}}<span class="abbr">{{.Abbr}}</span>{{end}}
        <div>
          <h3>{{.Name}}</h3>
          {{if .Description}}<div class="desc">{{.Description}}</div>{{end}}
        </div>
      </a>
    {{end}}
  </div>
{{end}}
